# MongoDB Atlas Connection String
# Get this from MongoDB Atlas: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://username:password@cluster.mongodb.net/databasename?retryWrites=true&w=majority
ATLAS_URI=mongodb+srv://username:password@cluster.mongodb.net/employees?retryWrites=true&w=majority

# Server Configuration
PORT=5050

# Optional: JWT Secret (for future authentication)
# JWT_SECRET=your_jwt_secret_key_here

# Optional: Environment
NODE_ENV=development
